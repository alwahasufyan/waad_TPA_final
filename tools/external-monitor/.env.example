# WAAD External Monitor configuration
# Copy to .env and fill in. This process runs OUTSIDE the WAAD backend.

# Targets to check (use URLs reachable from where the monitor runs).
WAAD_MONITOR_BACKEND_URL=http://backend:8080/actuator/health
WAAD_MONITOR_FRONTEND_URL=http://frontend:80
# Optional DB health URL (leave empty to skip):
WAAD_MONITOR_DB_HEALTH_URL=

# Telegram (same bot/chat you already tested inside the app):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_THREAD_ID=

# Timing:
WAAD_MONITOR_INTERVAL_SECONDS=60
WAAD_MONITOR_COOLDOWN_SECONDS=900
WAAD_MONITOR_TIMEOUT_MS=10000
WAAD_MONITOR_ENVIRONMENT=production

# Heartbeat back into WAAD so the admin UI shows the watchdog is alive (optional):
WAAD_MONITOR_HEARTBEAT_URL=http://backend:8080/api/v1/system/monitoring/external-heartbeat
# If the backend sets WAAD_MONITOR_HEARTBEAT_TOKEN, put the same value here:
WAAD_MONITOR_HEARTBEAT_TOKEN=
