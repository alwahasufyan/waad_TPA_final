# WAAD production Docker environment
# Copy to .env.production on the VPS. Never commit the real file.

SPRING_PROFILES_ACTIVE=prod
POSTGRES_DB=tba_waad_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
DB_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
JWT_SECRET=CHANGE_ME_GENERATED_WITH_OPENSSL_RAND_BASE64_48
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

EMAIL_ENABLED=true
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USERNAME=CHANGE_ME_SMTP_USERNAME
EMAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
EMAIL_FROM=support@alwahacare.com

VITE_API_URL=/api/v1
FILE_STORAGE_TYPE=local
FILE_STORAGE_LOCAL_BASE_DIR=/app/uploads

# Server-side backup destination mounted into the backend container.
# Do not point this at a browser user's PC path.
BACKUP_LOCAL_1_HOST=/opt/waad/backups/local
BACKUP_LOCAL_1_CONTAINER=/app/backups/local1

# MON-1A/MON-1B Telegram monitoring placeholders.
# Store real values only in .env.production on the VPS.
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_THREAD_ID=
TELEGRAM_ALERT_ENVIRONMENT=production
TELEGRAM_ALERT_MIN_INTERVAL_SECONDS=300
TELEGRAM_ALERT_RECOVERY_ENABLED=true
MONITORING_AUTOMATIC_ENABLED=false
MONITORING_CHECK_INTERVAL_SECONDS=300
MONITORING_DISK_WARNING_PERCENT=80
MONITORING_DISK_CRITICAL_PERCENT=90
MONITORING_MAX_BACKUP_AGE_HOURS=72
MONITORING_REPEATED_ERROR_THRESHOLD=10
MONITORING_REPEATED_ERROR_WINDOW_MINUTES=15
MONITORING_ALERT_COOLDOWN_SECONDS=1800

JAVA_OPTS=-Xms512m -Xmx1536m -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# --- Medical Classification: optional LAB reference layer (MED-DICT-9) ---
# Additive, versioned, rollback-safe recognition layer built from the approved
# WAAD_COMPRESSED LAB AUTO concepts. It emits CAT-LAB only and never overrides
# the official taxonomy. Default off = engine behaviour identical to baseline.
# Enable only after the reviewer spot-check sign-off.
ENGINE_WAAD_LAB_REFERENCE_ENABLED=false
ENGINE_WAAD_LAB_REFERENCE_PATH=/app/tools/classification-engine/waad_lab_reference_layer_v1.json
