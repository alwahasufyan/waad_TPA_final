# WAAD production Docker environment
# Copy to .env.production on the VPS. Never commit the real file.

SPRING_PROFILES_ACTIVE=prod
POSTGRES_DB=tba_waad_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
DB_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
JWT_SECRET=CHANGE_ME_GENERATED_WITH_OPENSSL_RAND_BASE64_48
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

EMAIL_ENABLED=true
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USERNAME=CHANGE_ME_SMTP_USERNAME
EMAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
EMAIL_FROM=support@alwahacare.com

VITE_API_URL=/api/v1
FILE_STORAGE_TYPE=local
FILE_STORAGE_LOCAL_BASE_DIR=/app/uploads

# Server-side backup destination mounted into the backend container.
# Do not point this at a browser user's PC path.
BACKUP_LOCAL_1_HOST=/opt/waad/backups/local
BACKUP_LOCAL_1_CONTAINER=/app/backups/local1

JAVA_OPTS=-Xms512m -Xmx1536m -XX:+UseG1GC -XX:MaxGCPauseMillis=200
